<mvc:View
    controllerName="customviewbookshop.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
>
    <Page id="page">
        <tnt:ToolHeader
            id="shellLikeToolHeader"
            class="sapUiTinyMargin"
        >
            <Button
                id="_IDGenButton2"
                icon="sap-icon://menu2"
                type="Transparent"
                tooltip="Menu"
                press=".onCollapseExpandPress"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData"
                        priority="NeverOverflow"
                    />
                </layoutData>
            </Button>
            <Image
                id="_IDGenImage"
                src="test-resources/sap/tnt/images/SAP_Logo.png"
                decorative="false"
                press=".onLogoPressed"
                tooltip="SAP Logo"
                width="60px"
                height="30px"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData1"
                        priority="NeverOverflow"
                    />
                </layoutData>
            </Image>
            <Title
                text="Prоduct Name"
                wrapping="false"
                id="productName"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData2"
                        priority="Disappear"
                    />
                </layoutData>
            </Title>
            <Text
                text="Second title"
                wrapping="false"
                id="secondTitle"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData3"
                        priority="Disappear"
                    />
                </layoutData>
            </Text>
            <ToolbarSpacer id="_IDGenToolbarSpacer" />
            <SearchField
                width="25rem"
                id="searchField"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData4"
                        priority="Low"
                        group="1"
                    />
                </layoutData>
            </SearchField>
            <Button
                visible="false"
                icon="sap-icon://search"
                type="Transparent"
                id="searchButton"
                tooltip="Search"
            />
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton"
                icon="sap-icon://da"
                type="Transparent"
                tooltip="Joule"
                text="Joule"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData5"
                        group="2"
                    />
                </layoutData>
            </OverflowToolbarButton>
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton1"
                icon="sap-icon://source-code"
                type="Transparent"
                tooltip="Action 1"
                text="Action 1"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData6"
                        group="2"
                    />
                </layoutData>
            </OverflowToolbarButton>
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton2"
                icon="sap-icon://card"
                type="Transparent"
                tooltip="Action 2"
                text="Action 2"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData7"
                        group="2"
                    />
                </layoutData>
            </OverflowToolbarButton>
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton3"
                icon="sap-icon://action-settings"
                type="Transparent"
                text="Settings"
            />
            <Button
                id="_IDGenButton3"
                icon="sap-icon://bell"
                type="Transparent"
                tooltip="Notification"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData8"
                        priority="NeverOverflow"
                    />
                </layoutData>
            </Button>
            <tnt:ToolHeaderUtilitySeparator
                id="_IDGenToolHeaderUtilitySeparator"
            />
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton4"
                icon="sap-icon://grid"
                type="Transparent"
                text="My Products"
                tooltip="My Products"
            />
            <Avatar
                id="_IDGenAvatar"
                src="test-resources/sap/tnt/images/Woman_avatar_01.png"
                displaySize="XS"
                press=".onAvatarPressed"
                tooltip="Profile"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData9"
                        priority="NeverOverflow"
                    />
                </layoutData>
            </Avatar>
        </tnt:ToolHeader>

        <!-- Side navigation -->
        <HBox id="_IDGenHBox3">
            <VBox id="_IDGenVBox">
                <tnt:SideNavigation
                    id="sideNavigation"
                    selectedKey="walked"
                    expanded="true"
                >
                    <tnt:NavigationList id="_IDGenNavigationList1">
                        <tnt:NavigationListItem
                            id="_IDGenNavigationListItem"
                            text="Home"
                            icon="sap-icon://home"
                        />
                        <tnt:NavigationListGroup
                            id="_IDGenNavigationListGroup"
                            text="New"
                        >
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem1"
                                text="Add Books"
                                icon="sap-icon://people-connected"
                                press="onAddBookPressed"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem2"
                                text="Building"
                                icon="sap-icon://building"
                            >
                                <tnt:NavigationListItem
                                    id="_IDGenNavigationListItem3"
                                    text="Office 01"
                                />
                                <tnt:NavigationListItem
                                    id="_IDGenNavigationListItem4"
                                    text="Office 02"
                                />
                            </tnt:NavigationListItem>
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem5"
                                text="Mileage"
                                icon="sap-icon://mileage"
                            >
                                <tnt:NavigationListItem
                                    id="_IDGenNavigationListItem6"
                                    text="Driven"
                                />
                                <tnt:NavigationListItem
                                    text="Walked"
                                    id="walked"
                                />
                            </tnt:NavigationListItem>
                        </tnt:NavigationListGroup>
                        <tnt:NavigationListGroup
                            id="_IDGenNavigationListGroup1"
                            text="Recently used"
                        >
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem7"
                                text="View Books"
                                icon="sap-icon://kpi-managing-my-area"
                                press="onViewDetailsBookPressed"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem8"
                                text="Flight"
                                icon="sap-icon://flight"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem9"
                                text="Map"
                                icon="sap-icon://map-2"
                            />
                        </tnt:NavigationListGroup>
                        <tnt:NavigationListGroup
                            id="_IDGenNavigationListGroup2"
                            text="Restricted"
                            enabled="false"
                        >
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem10"
                                text="Running"
                                icon="sap-icon://physical-activity"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem11"
                                text="Scissors"
                                icon="sap-icon://scissors"
                            />
                        </tnt:NavigationListGroup>
                        <tnt:NavigationListItem
                            id="_IDGenNavigationListItem12"
                            text="Transport"
                            icon="sap-icon://passenger-train"
                        />
                    </tnt:NavigationList>
                    <tnt:fixedItem>
                        <tnt:NavigationList id="_IDGenNavigationList2">
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem13"
                                text="Bar Chart"
                                icon="sap-icon://bar-chart"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem14"
                                selectable="false"
                                href="https://sap.com"
                                target="_blank"
                                text="External Link"
                                icon="sap-icon://attachment"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem15"
                                selectable="false"
                                href="https://sap.com"
                                target="_top"
                                text="External Link _top"
                                icon="sap-icon://attachment"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem16"
                                text="Compare"
                                icon="sap-icon://compare"
                            />
                        </tnt:NavigationList>
                    </tnt:fixedItem>
                </tnt:SideNavigation>
            </VBox>

            <VBox id="_IDGenVBox8">
                <!-- Panel 1 -->
                <Panel
                    id="Panel1"
                    class="sapUiResponsiveMargin"
                    accessibleRole="Region"
                    width="60rem"
                    visible="false"
                >
                    <headerToolbar>
                        <OverflowToolbar id="_IDGenOverflowToolbar">
                            <Title
                                id="_IDGenTitle"
                                text="Add New Item"
                            />
                        </OverflowToolbar>
                    </headerToolbar>

                    <Breadcrumbs
                        id="_IDGenBreadcrumbs"
                        currentLocationText="Add new Item"
                    >
                        <Link
                            id="_IDGenLink"
                            text="Master"
                        />
                    </Breadcrumbs>

                    <HBox id="_IDGenHBox">
                        <VBox id="_IDGenVBox1">
                            <Label
                                id="_IDGenLabel"
                                text="Title"
                            />
                            <Input
                                placeholder="Enter Your Title"
                                id="title"
                            />
                        </VBox>
                        <VBox id="_IDGenVBox2">
                            <Label
                                id="_IDGenLabel1"
                                text="Author"
                            />
                            <Input
                                placeholder="Enter Your Author"
                                id="author"
                            />
                        </VBox>
                        <VBox id="_IDGenVBox3">
                            <Label
                                id="_IDGenLabel2"
                                text="Price"
                            />
                            <Input
                                placeholder="Enter Your Price"
                                id="price"
                            />
                        </VBox>
                    </HBox>
                    <HBox id="_IDGenHBox1">
                        <VBox id="_IDGenVBox4">
                            <Label
                                id="_IDGenLabel3"
                                text="Stock"
                            />
                            <Input
                                placeholder="Enter the stock"
                                id="stock"
                            />
                        </VBox>
                        <VBox id="_IDGenVBox5">
                            <Label
                                id="_IDGenLabel4"
                                text="Location"
                            />
                            <Input
                                placeholder="Enter the Location"
                                id="location"
                            />
                        </VBox>
                        <VBox id="_IDGenVBox6">
                            <Label
                                id="_IDGenLabel5"
                                text="Genre"
                            />
                            <Input
                                placeholder="Enter the Genre"
                                id="genre"
                            />
                        </VBox>
                    </HBox>
                    <HBox id="_IDGenHBox2">
                        <VBox id="_IDGenVBox7">
                            <Button
                                id="_IDGenButton"
                                press="submit"
                                text="Submit"
                            />
                        </VBox>
                    </HBox>
                </Panel>
                <!-- Panel 2 -->
                <Panel
                    id="Panel2"
                    class="sapUiResponsiveMargin"
                    headerText="Book Details"
                    visible="false"
                >
                    <!-- Books Table -->
                    <Table
                        id="bookTable"
                        items="{/Books}"
                    >
                        <columns>
                            <Column id="_IDGenColumn1">
                                <Text
                                    id="_IDGenText"
                                    text="Title"
                                />
                            </Column>
                            <Column id="_IDGenColumn2">
                                <Text
                                    id="_IDGenText1"
                                    text="Author"
                                />
                            </Column>
                            <Column id="_IDGenColumn3">
                                <Text
                                    id="_IDGenText2"
                                    text="Price"
                                />
                            </Column>
                            <Column id="_IDGenColumn4">
                                <Text
                                    id="_IDGenText3"
                                    text="Stock"
                                />
                            </Column>
                            <Column id="_IDGenColumn5">
                                <Text
                                    id="_IDGenText4"
                                    text="Location"
                                />
                            </Column>
                            <Column id="_IDGenColumn6">
                                <Text
                                    id="_IDGenText5"
                                    text="Genre"
                                />
                            </Column>
                            <Column id="_IDGenColumn7">
                                <Text
                                    id="_IDGenText12"
                                    text="Action"
                                />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem id="_IDGenColumnListItem">
                                <cells>
                                    <Text
                                        id="_IDGenText6"
                                        text="{title}"
                                    />
                                    <Text
                                        id="_IDGenText7"
                                        text="{author}"
                                    />
                                    <Text
                                        id="_IDGenText8"
                                        text="{price}"
                                    />
                                    <Text
                                        id="_IDGenText9"
                                        text="{stock}"
                                    />
                                    <Text
                                        id="_IDGenText10"
                                        text="{location}"
                                    />
                                    <Text
                                        id="_IDGenText11"
                                        text="{genre}"
                                    />
                                    <Button
                                        id="button1"
                                        text="..." press="onActionPressed($event)"
                                    />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>
            </VBox>
        </HBox>
    </Page>
</mvc:View>
