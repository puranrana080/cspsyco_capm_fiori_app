<mvc:View
    controllerName="customviewbookshop.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <Page
        id="page"
        title="Welcome to SAPUI5"
    >
        <Breadcrumbs id="_IDGenBreadcrumbs" currentLocationText="Add new Item">
            <Link id="_IDGenLink" text="Master" />
        </Breadcrumbs>

        <HBox id="_IDGenHBox">
            <VBox id="_IDGenVBox1">
                <Label id="_IDGenLabel" text="Title" />
                <Input
                    placeholder="Enter Your Title"
                    id="title"
                />
            </VBox>
            <VBox id="_IDGenVBox2">
                <Label id="_IDGenLabel1" text="Author" />
                <Input
                    placeholder="Enter Your Author"
                    id="author"
                />
            </VBox>
            <VBox id="_IDGenVBox3">
                <Label id="_IDGenLabel2" text="Price" />
                <Input
                    placeholder="Enter Your Price"
                    id="price"
                />
            </VBox>
        </HBox>
        <HBox id="_IDGenHBox1">
            <VBox id="_IDGenVBox4">
                <Label id="_IDGenLabel3" text="Stock" />
                <Input
                    placeholder="Enter the stock"
                    id="stock"
                />
            </VBox>
            <VBox id="_IDGenVBox5">
                <Label id="_IDGenLabel4" text="Location" />
                <Input
                    placeholder="Enter the Location"
                    id="location"
                />
            </VBox>
            <VBox id="_IDGenVBox6">
                <Label id="_IDGenLabel5" text="Genre" />
                <Input
                    placeholder="Enter the Genre"
                    id="genre"
                />
            </VBox>
        </HBox>
        <HBox id="_IDGenHBox2" >
        <VBox id="_IDGenVBox7" >
        <Button id="_IDGenButton" press="submit" text="Submit"></Button>
        </VBox>
        </HBox>
    </Page>
</mvc:View>
